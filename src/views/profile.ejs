<%
const body = `
<div class="page-header" style="align-items: center; justify-content: space-between;">
  <h1>My Profile</h1>
  <div style="display: flex; gap: 1rem; align-items: center;">
    <div class="ws-indicator" id="wsIndicator" title="Real-time connection">
      <span class="ws-dot"></span><span class="ws-label">Live</span>
    </div>
    <div class="notification-bell" id="notifBell">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:24px;height:24px;"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
      <span class="notif-badge" id="notifBadge" style="display:none">0</span>
    </div>
  </div>
</div>

${ typeof error !== 'undefined' && error ? '<div class="alert alert-error">' + error + '</div>' : '' }

<div class="profile-grid">
  <div class="dashboard-card">
    <div class="profile-avatar-section">
      <div class="profile-avatar-large">${ profileUser ? profileUser.name[0].toUpperCase() : 'U' }</div>
      <div>
        <h2>${ profileUser ? profileUser.name : '' }</h2>
        <p class="text-muted">${ profileUser ? profileUser.email : '' }</p>
        <span class="badge badge-amber">${ profileUser ? profileUser.role : '' }</span>
      </div>
    </div>
  </div>

  <div class="dashboard-card">
    <div class="card-header"><h2>Edit Profile</h2></div>
    <form id="profileForm">
      <div class="form-group"><label>Phone</label><input type="tel" id="phone" value="${ profileUser && profileUser.profile && profileUser.profile.phone ? profileUser.profile.phone : '' }" placeholder="+40 700 000 000"/></div>
      <div class="form-group"><label>City</label><input type="text" id="profileCity" value="${ profileUser && profileUser.profile && profileUser.profile.city ? profileUser.profile.city : '' }" placeholder="Your city"/></div>
      <div class="form-group"><label>Years of Experience</label><input type="number" id="yearsExp" value="${ profileUser && profileUser.profile ? profileUser.profile.yearsExperience : 0 }" min="0"/></div>
      <div class="form-group"><label>Bio</label><textarea id="bio" placeholder="Tell us about yourself...">${ profileUser && profileUser.profile && profileUser.profile.bio ? profileUser.profile.bio : '' }</textarea></div>
      <button type="submit" class="btn btn-primary">Save Profile</button>
    </form>
  </div>
</div>
`;
%>
<%- include('layout', { body, title, user, profileUser }) %>
