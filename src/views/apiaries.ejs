<%
const body = `
<div class="page-header" style="align-items: center;">
  <div>
    <h1>My Apiaries</h1>
    <p class="subtitle">Manage your apiary locations</p>
  </div>
  <div style="display: flex; gap: 1rem; align-items: center;">
    <div class="ws-indicator" id="wsIndicator" title="Real-time connection">
      <span class="ws-dot"></span><span class="ws-label">Live</span>
    </div>
    <div class="notification-bell" id="notifBell">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
      <span class="notif-badge" id="notifBadge" style="display:none">0</span>
    </div>
    <button class="btn btn-primary" onclick="showModal('addApiaryModal')" style="margin-left:1rem;">+ New Apiary</button>
  </div>
</div>

${ typeof error !== 'undefined' && error ? '<div class="alert alert-error">' + error + '</div>' : '' }

<div class="apiaries-grid" id="apiariesGrid">
  ${ apiaries.map(a => `
  <div class="apiary-card" data-id="${a.id}">
    <div class="apiary-card-header">
      <div class="apiary-card-icon">🏠</div>
      <div class="apiary-card-actions">
        <button class="icon-btn" onclick="editApiary('${a.id}', '${a.name}', '${a.city||''}', '${a.description||''}')" title="Edit">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        </button>
        <button class="icon-btn danger" onclick="deleteApiary('${a.id}')" title="Delete">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3,6 5,6 21,6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        </button>
      </div>
    </div>
    <h3 class="apiary-card-name">${a.name}</h3>
    <p class="apiary-card-city">${a.city || 'No location set'}</p>
    <div class="apiary-card-stats">
      <span class="badge badge-amber">${a.hives ? a.hives.length : 0} hives</span>
    </div>
    <a href="/apiaries/${a.id}/hives" class="btn btn-outline btn-full" style="margin-top:1rem">View Hives →</a>
  </div>
  `).join('') }
  ${ apiaries.length === 0 ? `
  <div class="empty-full">
    <div style="font-size:4rem">🏡</div>
    <h2>No apiaries yet</h2>
    <p>Create your first apiary to start tracking your hives.</p>
    <button class="btn btn-primary" onclick="showModal('addApiaryModal')">Create First Apiary</button>
  </div>` : '' }
</div>

<!-- Add Apiary Modal -->
<div class="modal-overlay" id="addApiaryModal" style="display:none">
  <div class="modal">
    <div class="modal-header"><h3>Add New Apiary</h3><button class="modal-close" onclick="hideModal('addApiaryModal')">×</button></div>
    <form id="addApiaryForm">
      <div class="form-group"><label>Name *</label><input type="text" name="name" id="apiaryName" required placeholder="My Apiary"/></div>
      <div class="form-group"><label>City</label><input type="text" name="city" id="apiaryCity" placeholder="City"/></div>
      <div class="form-group"><label>Description</label><textarea name="description" id="apiaryDesc" placeholder="Description..."></textarea></div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="hideModal('addApiaryModal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Create Apiary</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Apiary Modal -->
<div class="modal-overlay" id="editApiaryModal" style="display:none">
  <div class="modal">
    <div class="modal-header"><h3>Edit Apiary</h3><button class="modal-close" onclick="hideModal('editApiaryModal')">×</button></div>
    <form id="editApiaryForm">
      <input type="hidden" id="editApiaryId"/>
      <div class="form-group"><label>Name *</label><input type="text" id="editApiaryName" required/></div>
      <div class="form-group"><label>City</label><input type="text" id="editApiaryCity"/></div>
      <div class="form-group"><label>Description</label><textarea id="editApiaryDesc"></textarea></div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="hideModal('editApiaryModal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</div>
`;
%>
<%- include('layout', { body, title, user }) %>
