# Server
PORT=3000
SESSION_SECRET=apinote_secret_key_change_in_prod

# Database - Supabase PostgreSQL (fill in your credentials)
DB_HOST=aws-0-eu-central-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.your_project_ref
DB_PASS=your_supabase_password
DB_SSL=true

# Or use SQLite for local dev (set DB_DIALECT=sqlite)
DB_DIALECT=sqlite

# JWT Authentication
JWT_SECRET=apinote_jwt_secret_2024
JWT_REFRESH_SECRET=apinote_refresh_secret_2024

# Toggl Track Integration (optional)
TOGGL_API_TOKEN=your_toggl_api_token_here
TOGGL_WORKSPACE_ID=your_workspace_id_here
